# --- CONFIGURACIÓN DE DJANGO ---
SECRET_KEY=django-insecure-tu-clave-aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
SESSION_SECRET=genera-un-secreto-con-node-o-python

# --- CONFIGURACIÓN DE BASE DE DATOS (SUPABASE POSTGRES) ---
# Reemplaza con tu "Connection URI" de Supabase
DATABASE_URL=postgresql://postgres.[tu-id]:[password]@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# --- CONFIGURACIÓN DE SUPABASE (API/SDK) ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SECRET_KEY=tu_service_role_key_aqui
SUPABASE_PUBLISHABLE_KEY=tu_anon_key_para_frontend

# --- CONFIGURACIÓN JWT ---
ACCESS_TOKEN_LIFETIME_MINUTES=720
REFRESH_TOKEN_LIFETIME_DAYS=7
