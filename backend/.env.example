# Configuracion de la Base de Datos (Supabase PostgreSQL)
# Reemplaza la URL de abajo con el "Connection string" de tu proyecto en Supabase (Settings > Database)
# Ejemplo: postgres://postgres.[tu-id]:[tu-password]@aws-0-us-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite:///db.sqlite3

# Otras variables
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
