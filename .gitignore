# 📦 Botica NovaSalud - Root GitIgnore

# =========================================================
# FRONTEND (React + Vite)
# =========================================================

node_modules/
frontend/node_modules/

frontend/dist/
frontend/.vite/
*.vite

frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Vite cache
vite.config.ts.timestamp-*

# =========================================================
# TYPESCRIPT
# =========================================================

*.tsbuildinfo

# =========================================================
# BACKEND (Django)
# =========================================================

backend/venv/
backend/.env

backend/__pycache__/
backend/*.py[cod]
backend/*$py.class

backend/db.sqlite3
backend/*.sqlite3

backend/staticfiles/
backend/static/
backend/media/
backend/media/uploads/

# =========================================================
# PYTHON GENERAL
# =========================================================

.python-version

pip-log.txt
pip-delete-this-directory.txt

.tox/
.coverage
.cache

nosetests.xml
coverage.xml
htmlcov/

*.cover
*.pyc
*.pyo

.pytest_cache/

**/__pycache__/

# =========================================================
# LOGS
# =========================================================

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================================================
# ENV FILES
# =========================================================

.env
.env.local
*.env.*

!.env.example

# =========================================================
# IDEs / EDITORS
# =========================================================

.vscode/
.idea/

*.iml
*.swp
*.swo

*.sublime-project
*.sublime-workspace

# =========================================================
# OS FILES
# =========================================================

.DS_Store
Thumbs.db
Desktop.ini

# =========================================================
# LEGACY / OTHERS
# =========================================================

app/node_modules/
app/.env

nodemon.json

scratch/__pycache__/