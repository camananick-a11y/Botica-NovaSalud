# 📦 Botica NovaSalud - Root GitIgnore

# --- Frontend (React + Vite) ---
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# --- Backend (Django) ---
backend/venv/
backend/.env
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/db.sqlite3
backend/*.sqlite3
backend/staticfiles/
backend/media/

# --- Python General ---
.python-version
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.cache
nosetests.xml
coverage.xml
*.cover
*.pyc
.pytest_cache/

# --- General / Environment ---
.env
.env.local
*.log

# --- IDEs / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# --- Legacy / Others ---
app/node_modules/
app/.env
nodemon.json
scratch/__pycache__/
